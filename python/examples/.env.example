# .env.example — config for the async-xenapi example tools
#   create-vm-async.py   (create + start a VM)
#   vnc-direct.py        (relay a VM's VNC console to a local port)
#
# Setup:  cp .env.example .env  then edit. Auto-loaded from the current dir and
# the script's own dir. Precedence: real env var > .env file > built-in default;
# any value is also overridable per-run by a CLI flag.

XS_HOST=your-host.example.net   # XenServer host or pool master (IP/hostname)
XS_USER=root                    # host root account
XS_PASSWORD=changeme            # root password — keep the real .env out of version control
XS_LOCAL_PORT=5901              # vnc-direct.py default local VNC port (optional)
